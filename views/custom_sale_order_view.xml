<odoo>
        <record id="form_sale_inherit_customs" model="ir.ui.view">
        <field name="name">form.sale.inherit.customs</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="invisible">
                        state not in ('draft','sent','manager_approve','boss_approve')
                    </attribute>
                </xpath>

                <xpath expr="(//button[@name='action_confirm'])[2]" position="attributes">
                    <attribute name="invisible">
                        state not in ('sent')
                    </attribute>
                </xpath>

                <xpath expr="//field[@name='state']" position="replace">
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,sent,manager_approve,boss_approve,sale"/>
                </xpath>
                <xpath expr="//header" position="inside">
                    <button name="action_manager_approve"
                        type="object"
                        string="Manager Approve"
                        class="btn-primary"
                        groups="custom.group_sale_custom_manager"/>

                    <button name="action_boss_approve"
                        type="object"
                        string="Boss Approve"
                        class="btn-success"
                        groups="custom.group_sale_custom_boss"/>

                    <button name="action_start"
                        type="object"
                        string="Start"
                        class="btn-success"
                        groups="custom.group_sale_custom_user"/>

                    <button name="action_stop"
                        type="object"
                        string="Stop"
                        class="btn-success"
                        groups="custom.group_sale_custom_user"/>
                </xpath>
               <xpath expr="//notebook" position="inside">
                   <page string="Custom Lines">

                       <field name="custom_line_ids">
                            <list  editable="bottom">
                                <field name="select_line"/>
                                <field name="sale_order"/>
                                <field name="product_id"/>
                                <field name="quantities"/>
                                <field name="price"/>
                                <field name="subtotal"/>

                                <button name="action_reorder_line"
                                        type="object"
                                        string="Reorder"
                                        class="btn btn-primary"
                                        options='{"no_open": true}'/>
                            </list>
                        </field>
                    </page>
              </xpath>

            <xpath expr="//field[@name='custom_line_ids']" position="before">

                  <button name="action_reorder"
                    string="Reorder"
                    type="object"
                    class="btn btn-primary"/>

            </xpath>
            <xpath expr="//field[@name='product_template_id']" position="after">
                <field name="special_item"/>
            </xpath>

            <xpath expr="//field[@name='price_subtotal']" position="after">
                 <button name="action_special_item"
                    type="object"
                    string="Verify"
                    invisible="not special_item"/>
            </xpath>
            <xpath expr="//field[@name='product_template_id']" position="after">
                 <button name="action_bom"
                    type="object"
                    string="BOM"
                    invisible="bom_count == 0"/>
            </xpath>

            <xpath expr="//page[@name='other_information']" position="inside">
            <group name="timesheet" string="Timesheet">
                <field name="start_date"/>
                <field name="stop_date"/>
            </group>
        </xpath>

        <xpath expr="//notebook" position="inside">
                   <page string="Timesheet Update" name="timesheet_tab" autofocus="autofocus">

                         <field name="timesheet_html"
                               nolabel="1"
                               readonly="1"
                               widget="html"/>

<!--                       <field name="timesheet_update_ids">-->
<!--                            <list  create="0" delete="0">-->
<!--                                <field name="task_name"/>-->
<!--                                <field name="parent_id"/>-->
<!--                                <field name="allocation_source"/>-->
<!--                                <field name="source_allocated_hours" sum="Total"/>-->
<!--                                <field name="allocated_hours" sum="Total"/>-->
<!--                                <field name="total_used_hours" sum="Total"/>-->
<!--                                <field name="used_last_month" sum="Total"/>-->
<!--                                <field name="used_hours_period" sum="Total"/>-->
<!--                                <field name="remaining_hours_custom" sum="Total"/>-->
<!--                            </list>-->
<!--                       </field>-->
                   </page>
              </xpath>
        </field>
        </record>
</odoo>