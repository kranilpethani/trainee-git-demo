<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="account_move_view_form_inherit" model="ir.ui.view">
    <field name="name">account.move.view.form.inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

        <xpath expr="//sheet/group/group[1]" position="inside">
            <field name="courier_charges"/>
            <field name="split_method"/>

        </xpath>
        <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='product_id']" position="after">
            <field name="courier_charge"/>
        </xpath>

    </field>
    </record>
</odoo>