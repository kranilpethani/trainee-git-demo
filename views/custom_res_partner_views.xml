<odoo>
    <record id="res_partner_form_inherit_custom" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[2]/group" position="inside">
                <group name="credit_limit" string="Credit Limit">
                    <field name="sale_order_total"/>
                    <field name="limit"/>
                    <field name="credit_limit" invisible="not limit"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>